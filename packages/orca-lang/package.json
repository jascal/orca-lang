{
  "name": "@orcalang/orca-lang",
  "version": "0.1.21",
  "description": "Orca (Orchestrated State Machine Language) - an LLM-native code generation target",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./skills": {
      "import": "./dist/skills.js",
      "types": "./dist/skills.d.ts"
    },
    "./tools": {
      "import": "./dist/tools.js",
      "types": "./dist/tools.d.ts"
    }
  },
  "bin": {
    "orca": "dist/index.js"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "tsx src/index.ts verify",
    "compile": "tsx src/index.ts compile",
    "health-check": "tsx src/health-check.ts"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "js-yaml": "^4.1.1",
    "xstate": "^5.28.0"
  }
}
