{
  "name": "orca-monorepo",
  "version": "0.1.8",
  "private": true,
  "description": "Orca (Orchestrated State Machine Language) - monorepo",
  "scripts": {
    "build": "pnpm -r --filter './packages/orca-lang' --filter './packages/runtime-ts' --filter './packages/mcp-server' run build",
    "test": "pnpm -r run test",
    "test:lang": "pnpm --filter orca run test",
    "test:demo-ts": "pnpm --filter orca-demo-ts run test",
    "run:demo-ts": "pnpm --filter orca-demo-ts run cli",
    "run:demo-ts:ticket": "pnpm --filter orca-demo-ts run ticket-demo",
    "test:demo-python": ".venv/bin/python packages/demo-python/demo.py",
    "setup:python": "bash scripts/setup-python.sh",
    "test:demo-nanolab": ".venv/bin/python -m pytest packages/demo-nanolab/tests/ -v",
    "run:demo-nanolab": ".venv/bin/python -m nanolab --max-iters 100",
    "setup:go": "cd packages/runtime-go && go mod download && cd ../demo-go && go mod download",
    "build:demo-go": "cd packages/demo-go && go build -o trip ./cmd/trip",
    "build:demo-go:loan": "cd packages/demo-go && go build -o loan ./cmd/loan",
    "test:demo-go": "cd packages/demo-go && go build -o trip ./cmd/trip && ./trip",
    "run:demo-go:loan": "cd packages/demo-go && go build -o loan ./cmd/loan && ./loan",
    "setup:rust": "cd packages/runtime-rust && cargo build --release",
    "test:rust": "cd packages/runtime-rust && cargo test",
    "build:demo-fortran": "cd packages/demo-fortran && make build-rust && make",
    "test:demo-fortran": "cd packages/demo-fortran && make run",
    "build:demo-rust": "cd packages/demo-rust && cargo build --release",
    "test:demo-rust": "cd packages/demo-rust && cargo test",
    "run:demo-rust": "cd packages/demo-rust && cargo run --release",
    "run:demo-rust:help": "cd packages/demo-rust && cargo run --release -- --help",
    "health-check": "cd packages/orca-lang && pnpm run health-check",
    "clean": "pnpm -r exec rm -rf dist"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0"
  }
}
